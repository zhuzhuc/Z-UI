# Copy to /etc/z-ui/z-ui.env and edit values.

GIN_MODE=release
PORT=8081

PANEL_USERNAME=admin
PANEL_PASSWORD=CHANGE_ME
PANEL_SECRET=CHANGE_ME_LONG_RANDOM
PANEL_PUBLIC_BASE=https://panel.example.com
AUTH_MAX_FAILURES=5
AUTH_FAIL_WINDOW_SEC=600
AUTH_LOCK_SEC=900

ZUI_DB=/opt/z-ui/data/zui.db
ZUI_FRONT_DIR=/opt/z-ui/front/dist

XRAY_CONTROL=systemd
XRAY_SERVICE=xray
XRAY_CONFIG=/opt/z-ui/runtime/xray-config.json
XRAY_ACCESS_LOG=/opt/z-ui/runtime/xray-access.log
XRAY_ERROR_LOG=/opt/z-ui/runtime/xray-error.log

CORS_ALLOW_ORIGINS=https://panel.example.com
TRUSTED_PROXIES=127.0.0.1,::1
